# BRC MCP Server configuration
BRC_API_BASE_URL=https://app.bigredcloud.com/api
PORT=3000

# MCP session configuration (default about 2 hours each)
BRC_MCP_SESSION_TTL_MINUTES=120
# How long a stored company API key stays valid in MCP memory (stdio and HTTP)
BRC_API_KEY_TTL_MINUTES=120

# Server rate limiting
# Default: 100 requests per minute per IP address
BRC_RATE_LIMIT_REQUESTS_PER_MINUTE=300

# Skill visibility and permissions
# If false, matching tools should not appear in Cursor/Claude and should not be accepted.
BRC_ALLOW_READ_SKILLS=true
BRC_ALLOW_UPDATE_SKILLS=true
BRC_ALLOW_DELETE_SKILLS=true
BRC_ALLOW_EMAIL_SKILLS=true
BRC_ALLOW_BATCH_SKILLS=true
# Dev mode exposes operator-only deployment diagnostics (brc_get_dev_mode_details). Default off for customer deployments.
BRC_ALLOW_DEV_MODE=false

# Operational limits (default 5; server caps at 10)
BRC_MAX_BATCH_ITEMS=5
BRC_MAX_AUDIT_ENTRIES=500

# API key blacklist
# Store SHA-256 hashes of blocked API keys, comma separated.
# Do not store raw API keys here.
BRC_API_KEY_BLACKLIST_SHA256=

# Public URL for the Red /connect page (hosted deployments)
BRC_PUBLIC_BASE_URL=https://red.bigredcloud.com

# Red connection persistence
# memory = local/Cursor in-process fallback
# cosmos = shared Cosmos DB persistence for hosted ChatGPT and multi-instance deployments
RED_CONNECT_CONNECTION_STORE=memory
RED_CONNECT_COSMOS_CONNECTION_STRING=
RED_CONNECT_COSMOS_DATABASE=red-connect
RED_CONNECT_COSMOS_CONTAINER=connections
# Recommended when RED_CONNECT_CONNECTION_STORE=cosmos (encrypts API keys at rest)
RED_CONNECT_ENCRYPTION_KEY=

# Set automatically when running the HTTP MCP server (remote.ts)
RED_CONNECT_HTTP_MODE=true
